<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_wizard_rango_lista_form" model="ir.ui.view">
        <field name="name">wizard.rango.lista.form</field>
        <field name="model">wizard.rango.lista</field>
        <field name="arch" type="xml">
            <form string="Filtrar Consumo de Productos">
                <group>
                    <group>
                        <field name="fecha_desde"/>
                    </group>
                    <group>
                        <field name="fecha_hasta"/>
                    </group>
                </group>
                <footer>
                    <button string="Aplicar Filtro a la Lista" name="action_aplicar_filtro_lista" type="object" class="btn-primary"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>